{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-path",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "core:window:allow-destroy"
  ]
}